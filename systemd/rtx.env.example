# Optional host-specific overrides for the systemd unit.
# The service can start without this file; uncomment and adjust values as needed.

# Absolute path to the Python interpreter that has this repo's dependencies installed.
# RTX_PYTHON_EXE=/srv/rtx/.venv/bin/python

# HTTP bind settings. Port ownership stays in homelab-infra.
# RTX_BIND_HOST=0.0.0.0
# RTX_PORT=20031

# Logging and polling behaviour.
# RTX_LOG_PATH=/srv/rtx/logs/gpu-metrics.csv
# RTX_LOG_INTERVAL_SECONDS=30
# RTX_QUERY_TIMEOUT_SECONDS=5

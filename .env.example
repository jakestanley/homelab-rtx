# Canonical config for homelab-rtx.
# Used by Docker Compose (env_file), Windows NSSM (AppEnvironmentExtra),
# and Linux systemd (copy to /etc/rtx/rtx.env).

# Absolute path to a Python interpreter. Required when .venv/ does not yet exist
# and python.exe is not on PATH (e.g. NSSM running as LocalSystem).
RTX_PYTHON_EXE=/absolute/path/to/python

# HTTP bind settings. Port ownership stays in homelab-infra.
RTX_BIND_HOST=0.0.0.0
RTX_PORT=20031

# Metrics CSV (relative paths resolve from the working directory).
RTX_LOG_PATH=logs/gpu-metrics.csv
RTX_LOG_INTERVAL_SECONDS=30
RTX_QUERY_TIMEOUT_SECONDS=5

# InfluxDB v2 publishing (optional; omit or leave blank to disable).
# RTX_INFLUX_URL=https://metrics.stanley.arpa
# RTX_INFLUX_ORG=stanley
# RTX_INFLUX_BUCKET=climate
# RTX_INFLUX_TOKEN=your_write_token_here
# RTX_INFLUX_HOST=adler   # tag value written to InfluxDB; defaults to system hostname

# Windows NSSM service identity (optional; defaults shown).
# These are consumed by scripts/up.ps1 and not passed to the app.
# NSSM_SERVICE_NAME=homelab-rtx
# NSSM_DISPLAY_NAME=homelab-rtx GPU telemetry
# NSSM_DESCRIPTION=Host-run NVIDIA GPU telemetry service
